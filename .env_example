EUROCLAW_ENV=production
EUROCLAW_MODEL=qwen2.5:7b
LOCAL_LLM_ENDPOINT=http://localhost:11434
REDIS_HOST=localhost
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Firecracker MicroVM Paths
FC_KERNEL_PATH=/opt/euroclaw/vmlinux
FC_ROOTFS_PATH=/opt/euroclaw/rootfs.ext4

# Identity & SSO (Keycloak / Entra ID)
OIDC_ISSUER_URL=http://localhost:8080/realms/euroclaw
OIDC_AUDIENCE=euroclaw-api

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# WhatsApp Integration
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_id

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_telegram_token

# Email Integration
EUROCLAW_EMAIL=ai-agent@yourdomain.com
EUROCLAW_EMAIL_PASSWORD=secure_app_password
EUROCLAW_IMAP_SERVER=imap.yourdomain.com
EUROCLAW_SMTP_SERVER=smtp.yourdomain.com

# Microsoft Teams Integration (Azure Bot Service)
TEAMS_APP_ID=your-microsoft-app-id
TEAMS_APP_PASSWORD=your-microsoft-app-client-secret